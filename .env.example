APP_NAME=AppointmentBooking
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SMS_DRIVER=log
SMS_LOG_CHANNEL=stack

QUEUE_RETRY_AFTER=90
FAILED_DRIVER=database-uuids
